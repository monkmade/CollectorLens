{
  "manifest_version": 3,
  "name": "CollectorLens — Comic Value for eBay",
  "version": "0.2.0",
  "description": "Inline overlay for eBay comic listings: sold-comps range, key-issue marker, edition warning - no tab switching. Free, no account.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "CollectorLens — Comic Value for eBay",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": ["https://www.ebay.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://www.ebay.com/sch/*",
        "https://www.ebay.com/itm/*",
        "https://www.ebay.com/b/*"
      ],
      "js": ["config.js", "parser.js", "review.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["key-issues.json"],
      "matches": ["https://www.ebay.com/*"]
    }
  ]
}
